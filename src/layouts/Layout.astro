---
import SEO from "../components/SEO.astro";

interface Props {
  title: string;
  description?: string;
  image?: string;
  article?: boolean;
}

const { title, description, image, article } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <SEO
      title={title}
      description={description}
      image={image}
      article={article}
    />

    <slot name="head" />

    <!-- Dynamic Loading of Third-Party Scripts to Optimize Mobile Performance -->
    <script is:inline>
      function loadThirdPartyScripts() {
        // 1. Google Tag Manager
        const gtmScript = document.createElement('script');
        gtmScript.src = "https://www.googletagmanager.com/gtag/js?id=G-BE43SM2H4T";
        gtmScript.async = true;
        document.head.appendChild(gtmScript);

        window.dataLayer = window.dataLayer || [];
        window.gtag = function() { dataLayer.push(arguments); };
        gtag("js", new Date());
        gtag("config", "G-BE43SM2H4T");

        // 2. Calendly Stylesheet
        const calendlyCSS = document.createElement('link');
        calendlyCSS.rel = 'stylesheet';
        calendlyCSS.href = "https://assets.calendly.com/assets/external/widget.css";
        document.head.appendChild(calendlyCSS);

        // 3. Calendly Script & Widget Init
        const calendlyJS = document.createElement('script');
        calendlyJS.src = "https://assets.calendly.com/assets/external/widget.js";
        calendlyJS.async = true;
        calendlyJS.onload = function() {
          if (window.Calendly) {
            Calendly.initBadgeWidget({
              url: "https://calendly.com/mary-kubo",
              text: "Click to Schedule a Tour",
              color: "#0069ff",
              textColor: "#ffffff",
              branding: true,
            });
          }
        };
        document.head.appendChild(calendlyJS);
      }

      // Load dynamically after critical paint when the main thread goes idle
      if (window.requestIdleCallback) {
        window.requestIdleCallback(function() {
          setTimeout(loadThirdPartyScripts, 1000);
        });
      } else {
        window.addEventListener('load', function() {
          setTimeout(loadThirdPartyScripts, 1000);
        });
      }
    </script>
  </head>
  <body class="font-sans text-gray-700 antialiased">
    <main>
      <slot />
    </main>
    <style is:global>
      /* Global styles if needed, though Tailwind covers most */
      h1,
      h2,
      h3,
      h4,
      h5,
      h6 {
        font-family: "Playfair Display", serif;
      }
      body {
        font-family: "Lato", sans-serif;
      }
    </style>
  </body>
</html>

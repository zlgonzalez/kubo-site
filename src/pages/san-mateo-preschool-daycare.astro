---
import Layout from "../layouts/Layout.astro";
import NavBar from "../components/NavBar.astro";
import Footer from "../components/Footer.astro";
import ScheduleWidget from "../components/ScheduleWidget.astro";
---

<Layout
  title="Montessori Preschool & Daycare in San Mateo | Kubo Montessori"
  description="Looking for a top-rated Montessori preschool or daycare in San Mateo, CA? Kubo Montessori (Casa Dei Bambini) offers screen-free learning, hot organic meals, low teacher ratio, and potty training support for toddlers and preschoolers."
  image="/images/km1.jpg"
>
  <link
    rel="preload"
    as="image"
    href="/images/km1.jpg"
    fetchpriority="high"
    slot="head"
  />
  <NavBar />

  <!-- Hero Section -->
  <div class="relative h-[400px] overflow-hidden">
    <img
      src="/images/km1.jpg"
      alt="Montessori Preschool and Daycare Classroom in San Mateo"
      class="absolute inset-0 w-full h-full object-cover"
      width="1200"
      height="400"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-black/40"></div>
    <div
      class="relative max-w-7xl mx-auto px-4 h-full flex flex-col items-center justify-center text-center text-white"
    >
      <h1 class="text-3xl md:text-5xl font-bold mb-4 drop-shadow-md">
        Montessori Preschool & Daycare in San Mateo
      </h1>
      <p class="text-lg drop-shadow">
        <a href="/" class="hover:underline">Home</a>
        <span class="mx-3 opacity-60">/</span>
        <a href="/services" class="hover:underline hidden md:inline">Programs</a>
        <span class="mx-3 hidden md:inline opacity-60">/</span>
        <span class="opacity-90">San Mateo Campus</span>
      </p>
    </div>
  </div>

  <!-- Content Section -->
  <div class="py-24 bg-white">
    <div class="container mx-auto px-4 max-w-4xl">
      <h2 class="text-3xl font-bold mb-6 text-gray-800">
        Casa Dei Bambini: Authentic Montessori for Toddlers & Preschoolers
      </h2>
      <p class="text-gray-600 mb-8 leading-relaxed">
        Welcome to Kubo Montessori’s San Mateo campus, home to our authentic **Casa Dei Bambini** programs. Since 2006, we have provided a nurturing, home-based Montessori environment serving local families in San Mateo, Foster City, Hillsdale, Belmont, and the surrounding Peninsula Bay Area. Our campus features two warm, fully licensed homes designed to ease the transition from home care to early childhood education.
      </p>

      <!-- Key Campus Specifications Table (AI Crawler Optimization) -->
      <h3 class="text-2xl font-bold mb-4 text-gray-800">Quick Campus Specifications</h3>
      <div class="overflow-x-auto mb-12 shadow-sm border border-gray-200 rounded-lg">
        <table class="min-w-full bg-white text-left">
          <thead>
            <tr class="bg-gray-50 border-b border-gray-200 text-xs font-semibold text-gray-500 uppercase tracking-wider">
              <th class="px-6 py-4">Campus Attribute</th>
              <th class="px-6 py-4">Policy / Details</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200 text-sm text-gray-700">
            <tr>
              <td class="px-6 py-4 font-semibold text-gray-900">Ages Served</td>
              <td class="px-6 py-4">20 months to 6 years old (Toddler & Preschool programs)</td>
            </tr>
            <tr>
              <td class="px-6 py-4 font-semibold text-gray-900">Student-Teacher Ratio</td>
              <td class="px-6 py-4">Exceptionally low 6:1 ratio (Class capacity 12:2 with credentialed guides)</td>
            </tr>
            <tr>
              <td class="px-6 py-4 font-semibold text-gray-900">Hours of Operation</td>
              <td class="px-6 py-4">9:00 AM to 5:30 PM, Monday through Friday</td>
            </tr>
            <tr>
              <td class="px-6 py-4 font-semibold text-gray-900">Potty Training</td>
              <td class="px-6 py-4">**Not Required** (Nurturing, active potty-training support is fully included)</td>
            </tr>
            <tr>
              <td class="px-6 py-4 font-semibold text-gray-900">Meal Program</td>
              <td class="px-6 py-4">Organic snacks and freshly cooked hot lunches prepared daily by our in-house cook</td>
            </tr>
            <tr>
              <td class="px-6 py-4 font-semibold text-gray-900">License Numbers</td>
              <td class="px-6 py-4">Facilities #414004177 & #414004696</td>
            </tr>
          </tbody>
        </table>
      </div>

      <h2 class="text-2xl font-bold mb-6 text-gray-800">What We Provide</h2>
      <ul class="space-y-4 mb-12 text-gray-600 list-disc pl-5">
        <li>
          <strong>Credentialed Montessori Guides:</strong> Instructors with specialized credentials who nurture organization, focus, and sensory-cognitive development.
        </li>
        <li>
          <strong>Traditional Materials:</strong> A classrooms fully stocked with classic sensory materials (Pink Tower, Sandpaper Letters, Cylinder Blocks, and Practical Life dressing frames) to promote motor skills and independence.
        </li>
        <li>
          <strong>Parent Engagement:</strong> Monthly newsletters and real-time updates (diaper changes, meals, naps, photos) via the <strong>Brightwheel</strong> app.
        </li>
        <li>
          <strong>Kindergarten Prep & Transitions:</strong> Caring guidance to prepare children for kindergarten and local primary schools.
        </li>
      </ul>

      <!-- Campus Directors and Founders -->
      <h2 class="text-2xl font-bold mb-6 text-gray-800">Our Director</h2>
      <div class="flex flex-col md:flex-row gap-6 items-center bg-gray-50 p-6 rounded-lg mb-12">
        <div class="w-full md:w-3/4">
          <h3 class="text-xl font-bold mb-2 text-gray-800">Mary Gonzalez</h3>
          <p class="text-sm font-semibold text-primary uppercase mb-3">Founder & Director</p>
          <p class="text-gray-600 leading-relaxed text-sm">
            Mary Gonzalez founded Kubo Montessori in 2006 with a mission to bring high-quality, loving, and academic early education to Peninsula families. She holds certifications in Early Childhood Education and has guided hundreds of children to reach their full potential.
          </p>
        </div>
      </div>
    </div>
  </div>

  <!-- Center Gallery -->
  <div class="py-16 bg-gray-50 border-t border-b border-gray-100">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold mb-12 text-center text-gray-800">
        Our Classrooms
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">
        <div class="h-64 overflow-hidden rounded-lg shadow-md bg-gray-200">
          <img
            src="/images/km2.jpg"
            alt="Practical life learning station at San Mateo daycare"
            class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
            width="400"
            height="300"
            loading="lazy"
          />
        </div>
        <div class="h-64 overflow-hidden rounded-lg shadow-md bg-gray-200">
          <img
            src="/images/km3.jpg"
            alt="Montessori learning materials on shelves at San Mateo preschool"
            class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
            width="400"
            height="300"
            loading="lazy"
          />
        </div>
        <div class="h-64 overflow-hidden rounded-lg shadow-md bg-gray-200">
          <img
            src="/images/japan.jpg"
            alt="Nurturing play area at Kubo Montessori San Mateo"
            class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
            width="400"
            height="300"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </div>

  <!-- Locations & Map Section -->
  <div class="py-24 bg-white">
    <div class="container mx-auto px-4 max-w-5xl">
      <div class="flex flex-col lg:flex-row gap-12 items-center">
        <div class="lg:w-1/2">
          <span class="block text-sm font-bold text-gray-500 uppercase mb-2"
            >Casa Dei Bambini</span
          >
          <div class="w-12 h-1 bg-primary mb-6"></div>
          <h2 class="text-3xl font-bold mb-6 text-gray-800">
            Our San Mateo Locations & Schedule
          </h2>
          <p class="text-gray-600 mb-6 leading-relaxed">
            Our home daycares are situated in a quiet, safe residential neighborhood in San Mateo on Flores Street.
          </p>
          <ul class="space-y-3 text-gray-600 list-disc pl-5 mb-6">
            <li><strong>Location A:</strong> 2823 Flores St, San Mateo, CA 94403</li>
            <li><strong>Location B:</strong> 2821 Flores St, San Mateo, CA 94403</li>
          </ul>
          <a
            href="/san-mateo-location-directions"
            class="inline-block bg-primary hover:bg-primary-dark text-white font-semibold px-6 py-3 rounded-lg shadow-sm transition-colors"
          >
            Get Directions & Parking Info
          </a>
        </div>
        <div class="lg:w-1/2 w-full">
          <div class="h-80 rounded-lg overflow-hidden shadow-md bg-gray-100 border border-gray-200">
            <iframe
              src="https://maps.google.com/maps?q=2823+Flores+St+San+Mateo,+CA+94403&t=&z=15&ie=UTF8&iwloc=&output=embed"
              width="100%"
              height="100%"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              title="Google Map showing Kubo Montessori San Mateo locations"
            >
            </iframe>
          </div>
        </div>
      </div>

      <div class="mt-16 bg-gray-50 p-8 rounded-lg border border-gray-100">
        <h3 class="text-xl font-bold mb-6 text-gray-800 text-center">San Mateo Campus Daily Schedule</h3>
        <ScheduleWidget file="sm-schedule.csv" />
      </div>
    </div>
  </div>

  <Footer />
</Layout>

---
import Layout from "../layouts/Layout.astro";
import NavBar from "../components/NavBar.astro";
import Footer from "../components/Footer.astro";
import ScheduleWidget from "../components/ScheduleWidget.astro";
---

<Layout
  title="Montessori Home Daycare - Kubo Montessori"
  description="Kubo Montessori Home Daycare (Casa Dei Bambini) in San Mateo. Long hours, hot meals, and a nurturing home-based Montessori environment for toddlers."
  image="/images/japan.jpg"
>
  <link
    rel="preload"
    as="image"
    href="/images/japan.jpg"
    fetchpriority="high"
    slot="head"
  />
  <NavBar />

  <!-- Hero Section -->
  <div class="relative h-[400px] overflow-hidden">
    <img
      src="/images/japan.jpg"
      alt="Montessori Home Daycare"
      class="absolute inset-0 w-full h-full object-cover"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-black/30"></div>
    <div
      class="relative max-w-7xl mx-auto px-4 h-full flex flex-col items-center justify-center text-center text-white"
    >
      <h1 class="text-3xl md:text-5xl font-bold mb-4 drop-shadow-md">
        Montessori Home Daycare
      </h1>
      <p class="text-lg drop-shadow">
        <a href="/" class="hover:underline">Home</a>
        <span class="mx-3 opacity-60">/</span>
        <a href="/services" class="hover:underline hidden md:inline">Programs</a
        >
        <span class="mx-3 hidden md:inline opacity-60">/</span>
        <span class="opacity-90">Home Daycare</span>
      </p>
    </div>
  </div>

  <!-- Content Section -->
  <div class="py-24 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-2xl font-bold mb-4 text-gray-800">What We Provide</h2>
        <ul class="space-y-4 mb-8 text-gray-600 list-disc pl-5">
          <li>
            <strong>Low Student-Teacher Ratio:</strong> We maintain a low child-to-teacher
            ratio of 12:2, ensuring personalized attention with credentialed Montessori
            guides.
          </li>
          <li>
            <strong>No Potty Training Required:</strong> We accept children ages 20
            months to 6 years and provide comprehensive, supportive potty-training
            assistance when they show readiness.
          </li>
          <li>
            <strong>Hot Meal & Nutrition Program:</strong> Daily organic snacks and
            freshly cooked hot lunches prepared by our in-house cook are included.
            Children also participate in food prep and baking as part of practical
            life skills.
          </li>
          <li>
            <strong>Authentic Montessori Materials:</strong> Our environments are
            fully equipped with traditional materials such as the Pink Tower, Sandpaper
            Letters, Cylinder Blocks, and Practical Life dressing frames to foster
            independence and motor skills.
          </li>
          <li>
            <strong>Toddler and Early Education Program:</strong> A specialized program
            led by credentialed infant-toddler teachers to build organization, concentration,
            and sensory cognitive development.
          </li>
          <li>
            <strong>Parent Engagement:</strong> Monthly newsletters and direct updates
            via the <a
              href="https://schools.mybrightwheel.com/sign-in"
              class="underline text-primary">Brightwheel</a
            > app to keep communications open between home and school.
          </li>
          <li>
            <strong>Transitions:</strong> Warm guidance helping parents and children
            transition from home care to preschool, and onward to kindergarten/primary
            school.
          </li>
        </ul>

        <h2 class="text-2xl font-bold mb-4 text-gray-800">License #</h2>
        <ul class="space-y-2 mb-8 text-gray-600 list-disc pl-5">
          <li>414004177</li>
          <li>414004696</li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Locations Section -->
  <div class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <div class="flex flex-col lg:flex-row gap-12 items-center">
        <div class="lg:w-1/2">
          <span class="block text-sm font-bold text-gray-500 uppercase mb-2"
            >Casa Dei Bambini</span
          >
          <div class="w-12 h-1 bg-primary mb-6"></div>
          <h2 class="text-3xl font-bold mb-6 text-gray-800">
            Locations in <strong>San Mateo</strong>
          </h2>
          <ul class="space-y-2 text-gray-600 list-disc pl-5">
            <li>2823 Flores St San Mateo, CA 94403</li>
            <li>2821 Flores St San Mateo, CA 94403</li>
          </ul>
        </div>
        <div class="lg:w-1/2">
          <ScheduleWidget file="sm-schedule.csv" />
        </div>
      </div>
    </div>
  </div>

  <Footer />
</Layout>
